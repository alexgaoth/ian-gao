---
import Layout from '../layouts/Layout.astro';
import Ticker from '../components/Ticker.astro';
import { Image } from 'astro:assets';
import { SITE } from '../lib/site';
import { personSchema } from '../lib/schema';

import portrait from '../assets/ian-portrait.jpg';
import natsPhoto from '../assets/ian-nationals.jpg';
import stage1 from '../assets/ian-stage-1.png';
import stage2 from '../assets/ian-stage-2.jpg';
import ucsbPhoto from '../assets/ian-ucsb-research.png';
import mahanPhoto from '../assets/ian-mahan-campaign.png';

const tickerItems = ['LeBron is the GOAT'];

const debateResults = [
  { event: 'NSDA Nationals, LD', result: '19th in the Nation', year: '2026' },
  { event: 'CA State Championships, LD', result: 'Top 30', year: '2026' },
  { event: 'Philhistorian Invitational, Open LD', result: 'Champion', year: '2024' },
  { event: 'NSDA Last Chance Qualifier, Open LD', result: 'First Seed, Undefeated', year: '2025 & 2026' },
  { event: 'Stephen Stewart Invitational, Open LD', result: 'Quarterfinals', year: '2025' },
];

const debateBullets = [
  'I lead a nationally competitive team of 200 students — ranked 10th in the nation, the best public-school program in our district and among the top in California — competing at regional and national tournaments.',
  'I manage registration and communication for all judges, coaches, and tournaments, and oversee our ~20-person student leadership team of VPs and Chairs, heading biweekly leadership meetings and holding the team accountable.',
  'I headed and executed a complete overhaul of the team — restructuring from 2 to 5 periods, building a tailored roster by event, and facilitating the transition to a new head coach.',
  'As Captain of LD this past year, I wrote lesson plans and assignments for weekly meetings, mentored novice debaters, and led bimonthly topic-research sessions on issues like plea bargaining, the living wage, military intervention, and artificial general intelligence for my team of 20 debaters.',
];

const research = [
  {
    org: 'Cambridge Center of International Research',
    tag: 'CCIR',
    mentor: 'Mentored by Oxford Professor Dr. Othon Anastasakis',
    points: [
      'Authored a 15,000-word original research paper, “Bosnia and Herzegovina and the Limits of International State-Building: How Stable Is the Post-Dayton Order?”',
      'Presented twice at the CCIR Research Symposium.',
    ],
  },
  {
    org: 'UC Santa Barbara — Summer Research Academies',
    tag: 'Track 11: Policy Puzzle · June–July 2025',
    mentor: 'Mentored by PhD candidate Travis Candeias',
    points: [
      'Earned an A in INT 93LS — Applied Research Methods for Policy Analysis, covering quasi-experimental design and latent-variable modeling for policy evaluation.',
      'Co-authored “A Model Policing Agency: Analyzing the Impact of the Collaborative Reform Initiative on Use of Force in San Francisco.”',
      'Used R to analyze large SFPD use-of-force datasets from 2018–2023, evaluating the Collaborative Reform Initiative’s effectiveness by incident severity and demographics.',
    ],
  },
  {
    org: 'UC Santa Cruz — Science Internship Program',
    tag: 'PHI-03 · June 2026–present',
    mentor: 'Mentored by philosophy PhD candidate Terri Preszle',
    points: [
      '“What is Love? — A Philosophical Inquiry.”',
      'Close reading and annotation of ancient and contemporary philosophers on the many theories of love, contributing to my mentor’s doctoral thesis.',
    ],
  },
];

const campaigns = [
  {
    name: 'Matt Mahan for Governor of California',
    role: 'Campaign Intern & Phonebank Lead',
    dates: 'Feb 2026 – Jun 2026',
    points: [
      'Led weekly phone-banking sessions with 20+ volunteers, training them to reach tens of thousands of voters.',
      'Boosted voter turnout by helping organize town halls, GOTV rallies, meet-and-greets, and an election watch party across the Bay Area.',
      'Ran voter outreach — recruiting and managing volunteers for canvassing and literature drops across thousands of homes.',
    ],
  },
  {
    name: 'Evan Low for Congress',
    role: 'Campaign Intern',
    dates: 'Sep 2024 – Nov 2024',
    points: [
      'Phone banking, canvassing, and literature drops (~200 houses door-to-door).',
      'Weekly team meetings on campaign strategy and event planning.',
    ],
  },
];

const roles = [
  { lead: 'Greg Pierotti, Rulon Stacey', rest: 'Aaron McKinney, Shadow & The Bailiff', show: 'The Laramie Project', season: 'Winter 2023' },
  { rest: 'Kevin G / Ensemble', show: 'Mean Girls', season: 'Spring 2024' },
  { lead: 'Algernon Moncrieff', show: 'The Importance of Being Earnest', season: 'Winter 2024' },
  { rest: 'Sky', show: 'Mamma Mia', season: 'Spring 2025' },
  { rest: 'Set Crew Lead', show: 'Chicago', season: 'Winter 2025' },
  { lead: 'Colonel Mustard', show: 'Clue: On Stage', season: 'Spring 2026' },
];
---

<Layout
  title="Ian Gao"
  description="Ian Gao — senior at Leland High School. President of Leland Speech and Debate, ranked 19th nationally in LD. Research in history, policy analysis, and philosophy. Political campaigns, Leland theatre, essays."
  homepage
  structuredData={personSchema()}
>
  <!-- HERO -->
  <header id="top" class="hero">
    <div class="wrap hero-grid">
      <div>
        <p class="eyebrow accent-text">THE STUDY OF</p>
        <h1>Ian Gao</h1>
        <p class="tagline">philosophy&#8202;·&#8202;politics&#8202;·&#8202;policy</p>
        <div class="cta-row">
          <a href="/writing/" class="btn btn-accent">Read the writing →</a>
          <a href="/#debate" class="btn btn-outline">The record</a>
        </div>
      </div>
      <div class="portrait-frame">
        <Image
          src={portrait}
          alt="Ian Gao, senior at Leland High School"
          width={520}
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </header>

  <Ticker items={tickerItems} />

  <!-- WHO I AM -->
  <section class="section bg-cream">
    <div class="wrap who-grid">
      <div><p class="eyebrow oxblood-text">WHO I AM</p></div>
      <div class="who-body">
        <p class="lead-line">
          Hi! I'm Ian Gao, a senior at Leland High School and a student researcher at UC Santa Barbara in policy
          analysis and UC Santa Cruz in philosophy.
        </p>
        <p>
          I'm also the President of Debate at Leland Speech and Debate, a program of 200+ students ranked third in
          California and tenth in the nation. This summer I competed at the 2026 National Speech and Debate
          Tournament, where I placed 19th in the nation in Lincoln-Douglas Debate.
        </p>
        <p>
          Outside of research and debate, I enjoy acting as a cast member in Leland Theatre, interning for political
          campaigns I believe in, increasing civic engagement among young people through courtwatching, playing
          basketball, and learning a few songs on the guitar!
        </p>
      </div>
    </div>
  </section>

  <!-- DEBATE -->
  <section id="debate" class="section bg-cream3">
    <div class="wrap">
      <div class="section-heading">
        <h2>Speech and Debate</h2>
        <span class="tag">LD · POLICY · DUO · EXTEMP</span>
      </div>
      <figure class="section-photo center">
        <Image
          src={natsPhoto}
          alt="Ian holding his award at the 2026 NSDA National Speech and Debate Tournament"
          widths={[380, 760]}
          sizes="(min-width: 640px) 380px, 90vw"
          loading="lazy"
        />
        <figcaption>At the 2026 NSDA National Tournament.</figcaption>
      </figure>
      <div class="debate-grid">
        <div class="stat-card">
          <span class="kpi oxblood-text">19th</span>
          <p class="stat-label">IN THE NATION, LD (NSDA 2026)</p>
        </div>
        <div class="stat-card">
          <span class="kpi-text">President of Debate</span>
          <p class="stat-label">LELAND SPEECH &amp; DEBATE</p>
        </div>
        <div class="results-card">
          <div class="results-head">DEBATE RESULTS</div>
          <table>
            <thead class="sr-only">
              <tr>
                <th scope="col">Tournament</th>
                <th scope="col">Result</th>
                <th scope="col">Year</th>
              </tr>
            </thead>
            <tbody>
              {debateResults.map((r) => (
                <tr>
                  <td>{r.event}</td>
                  <td class="result">{r.result}</td>
                  <td class="year">{r.year}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
      <ul class="debate-bullets">
        {debateBullets.map((b) => (
          <li>{b}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- RESEARCH -->
  <section id="research" class="section bg-cream">
    <div class="wrap">
      <div class="section-heading">
        <h2>Research</h2>
        <span class="tag">HISTORY · POLICY · PHILOSOPHY</span>
      </div>
      <figure class="section-photo center">
        <Image
          src={ucsbPhoto}
          alt="Ian presenting a regression analysis of SFPD use-of-force data at UC Santa Barbara"
          widths={[380, 760]}
          sizes="(min-width: 640px) 380px, 90vw"
          loading="lazy"
        />
        <figcaption>Presenting our SFPD use-of-force analysis at UC Santa Barbara.</figcaption>
      </figure>
      <div class="research-grid">
        {research.map((r) => (
          <div class="research-card">
            <p class="research-tag">{r.tag}</p>
            <h3>{r.org}</h3>
            <p class="research-mentor">{r.mentor}</p>
            <ul class="card-bullets">
              {r.points.map((p) => (
                <li>{p}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CAMPAIGNING -->
  <section id="campaigning" class="section bg-cream3">
    <div class="wrap">
      <div class="section-heading">
        <h2>Campaigning</h2>
        <span class="tag">CALIFORNIA CAMPAIGNS</span>
      </div>
      <figure class="section-photo">
        <Image
          src={mahanPhoto}
          alt="Ian on the Matt Mahan for Governor campaign"
          widths={[600, 1000, 1400]}
          sizes="(min-width: 1080px) 1000px, 100vw"
          loading="lazy"
        />
        <figcaption>On the Matt Mahan for Governor campaign.</figcaption>
      </figure>
      <div class="campaign-grid">
        {campaigns.map((c) => (
          <div class="campaign-card">
            <div class="campaign-head">
              <h3>{c.name}</h3>
              <span class="campaign-dates">{c.dates}</span>
            </div>
            <p class="campaign-role">{c.role}</p>
            <ul class="card-bullets">
              {c.points.map((p) => (
                <li>{p}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STAGE -->
  <section id="stage" class="section bg-cream">
    <div class="wrap">
      <div class="section-heading">
        <h2>On Stage</h2>
        <span class="tag">LELAND THEATRE</span>
      </div>
      <div class="stage-photos">
        <div class="stage-cell">
          <Image src={stage1} alt="Ian performing on stage with Leland Theatre" widths={[320, 640]} sizes="(min-width: 640px) 50vw, 100vw" loading="lazy" />
        </div>
        <div class="stage-cell">
          <Image src={stage2} alt="Ian delivering a scene on stage with Leland Theatre" widths={[320, 640]} sizes="(min-width: 640px) 50vw, 100vw" loading="lazy" />
        </div>
      </div>
      <p class="stage-body">
        Six productions with Leland Theatre since 2023 — <em>The Laramie Project</em>, <em>Mean Girls</em>,{' '}
        <em>The Importance of Being Earnest</em>, <em>Mamma Mia</em>, <em>Chicago</em>, and <em>Clue</em>.
      </p>
      <ul class="roles-list">
        {roles.map((r) => (
          <li>
            <span class="role-name">
              {r.lead && <strong>{r.lead}</strong>}
              {r.lead && r.rest ? ', ' : ''}
              {r.rest}
            </span>
            <span class="role-show"><em>{r.show}</em></span>
            <span class="role-season">{r.season}</span>
          </li>
        ))}
      </ul>
      <a href="https://youtu.be/_pUo7QA8DPk" class="stage-link" rel="noopener">Watch some of my scenes! ↗</a>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="section bg-cream3 contact">
    <div class="wrap">
      <h2>Get in touch</h2>
      <p class="contact-body">The best way to reach me is a short email!</p>
      <div class="contact-row">
        <a href={`mailto:${SITE.email}`} class="btn btn-primary">✉&#8202;&#8202; Email me</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    background: var(--primary);
    color: var(--on-primary);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(900px 500px at 78% -10%, color-mix(in oklab, var(--accent) 22%, transparent), transparent 60%);
    pointer-events: none;
  }

  .hero-grid {
    padding-block: 60px 70px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
    position: relative;
  }

  @media (min-width: 860px) {
    .hero-grid {
      grid-template-columns: 1.55fr 1fr;
      padding-block: 76px 84px;
    }
  }

  .accent-text {
    color: var(--accent);
    margin: 0 0 22px;
  }

  .hero h1 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(46px, 9vw, 82px);
    line-height: 0.9;
    letter-spacing: -0.03em;
    color: var(--on-primary);
    margin: 0;
  }

  .tagline {
    font-size: 20px;
    font-style: italic;
    color: var(--on-primary-soft);
    margin: 18px 0 0;
  }

  .cta-row {
    display: flex;
    gap: 14px;
    margin-top: 32px;
    flex-wrap: wrap;
  }

  .btn {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.04em;
    padding: 13px 22px;
    border-radius: 7px;
    display: inline-block;
  }

  .btn-accent {
    color: var(--primary);
    background: var(--accent);
  }

  .btn-accent:hover {
    filter: brightness(1.06);
    color: var(--primary);
  }

  .btn-outline {
    color: var(--on-primary);
    border: 1px solid var(--on-primary-soft);
  }

  .btn-outline:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .btn-primary {
    color: var(--on-primary);
    background: var(--primary);
    font-size: 14px;
    padding: 15px 28px;
  }

  .btn-primary:hover {
    filter: brightness(1.1);
    color: var(--on-primary);
  }

  .portrait-frame {
    justify-self: center;
    padding: 10px;
    border: 1px solid var(--primary-tint);
    border-radius: 10px;
    background: color-mix(in oklab, var(--primary) 70%, black 8%);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.28);
    width: 260px;
  }

  .portrait-frame :global(img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 6px;
  }

  .section {
    padding-block: clamp(50px, 8vw, 82px);
  }

  .bg-cream {
    background: var(--cream);
  }

  .bg-cream3 {
    background: var(--cream3);
    border-top: 1px solid color-mix(in oklab, var(--ink) 12%, transparent);
    border-bottom: 1px solid color-mix(in oklab, var(--ink) 12%, transparent);
  }

  .who-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 30px;
  }

  @media (min-width: 780px) {
    .who-grid {
      grid-template-columns: 220px 1fr;
      gap: 56px;
    }
  }

  .oxblood-text {
    color: var(--oxblood);
    margin: 6px 0 0;
  }

  .who-body {
    font-size: 17px;
    line-height: 1.62;
    color: var(--ink);
  }

  .who-body p {
    margin: 0 0 18px;
    max-width: 40em;
  }

  .who-body p:last-child {
    margin-bottom: 0;
  }

  .lead-line {
    font-size: clamp(22px, 3vw, 30px);
    line-height: 1.35;
    color: var(--ink);
    font-weight: 500;
    text-wrap: pretty;
  }

  .debate-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    align-items: stretch;
  }

  @media (min-width: 780px) {
    .debate-grid {
      grid-template-columns: 1fr 1fr 1.4fr;
    }
  }

  .stat-card {
    border: 1px solid var(--accent);
    border-radius: 10px;
    padding: 22px;
    background: var(--cream2);
  }

  .kpi {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 52px;
    line-height: 0.85;
  }

  .kpi-text {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 30px;
    line-height: 0.95;
    color: var(--primary);
  }

  .stat-label {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin: 12px 0 0;
  }

  .results-card {
    border: 1px solid color-mix(in oklab, var(--ink) 16%, transparent);
    border-radius: 10px;
    overflow: hidden;
    background: var(--cream2);
  }

  .results-head {
    background: var(--primary);
    padding: 9px 16px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--accent);
  }

  .results-card table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-display);
    font-size: 13px;
  }

  .results-card td {
    padding: 9px 16px;
    border-bottom: 1px solid color-mix(in oklab, var(--ink) 10%, transparent);
    color: var(--ink);
  }

  .results-card tr:last-child td {
    border-bottom: 0;
  }

  .result {
    text-align: right;
    color: var(--oxblood);
    font-weight: 700;
  }

  .year {
    text-align: right;
    color: var(--muted);
    font-size: 11px;
    white-space: nowrap;
    padding-left: 8px;
  }

  /* enlarged per Ian's note — these bullets are the substance of the role */
  .debate-bullets {
    margin: 34px 0 0;
    padding-left: 22px;
    max-width: 60em;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .debate-bullets li {
    font-size: 18px;
    line-height: 1.6;
    color: var(--ink);
  }

  .debate-bullets li::marker {
    color: var(--accent);
  }

  .section-photo {
    margin: 0 0 34px;
  }

  .section-photo :global(img) {
    width: 100%;
    height: auto;
    border-radius: 10px;
    border: 1px solid color-mix(in oklab, var(--ink) 16%, transparent);
  }

  .section-photo.center {
    max-width: 380px;
    margin-inline: auto;
  }

  .section-photo figcaption {
    font-family: var(--font-display);
    font-size: 12.5px;
    letter-spacing: 0.02em;
    color: var(--muted);
    margin-top: 10px;
    text-align: center;
  }

  .research-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 780px) {
    .research-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .research-card {
    border: 1px solid color-mix(in oklab, var(--ink) 14%, transparent);
    border-radius: 10px;
    padding: 22px;
    background: var(--cream2);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .research-tag {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--oxblood);
    margin: 0;
    text-transform: uppercase;
  }

  .research-card h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 17px;
    color: var(--primary);
    margin: 0;
  }

  .research-mentor {
    font-size: 13.5px;
    font-style: italic;
    color: var(--muted);
    margin: 0;
  }

  .card-bullets {
    margin: 6px 0 0;
    padding-left: 18px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .card-bullets li {
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink);
  }

  .card-bullets li::marker {
    color: var(--accent);
  }

  .campaign-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 700px) {
    .campaign-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .campaign-card {
    border: 1px solid color-mix(in oklab, var(--ink) 14%, transparent);
    border-radius: 10px;
    padding: 22px;
    background: var(--cream2);
    display: flex;
    flex-direction: column;
  }

  .campaign-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
  }

  .campaign-head h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 17px;
    color: var(--primary);
    margin: 0;
  }

  .campaign-dates {
    font-family: var(--font-display);
    font-size: 11px;
    color: var(--muted);
    white-space: nowrap;
  }

  .campaign-role {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--oxblood);
    margin: 8px 0 10px;
  }

  .stage-photos {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 26px;
  }

  .stage-cell {
    height: clamp(240px, 40vw, 320px);
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid color-mix(in oklab, var(--ink) 16%, transparent);
  }

  .stage-cell :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .stage-body {
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink);
    margin: 0 0 18px;
    max-width: 62em;
  }

  .roles-list {
    list-style: none;
    padding: 0;
    margin: 0 0 22px;
    display: flex;
    flex-direction: column;
  }

  .roles-list li {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 6px 12px;
    padding: 12px 0;
    border-bottom: 1px solid color-mix(in oklab, var(--ink) 12%, transparent);
  }

  .roles-list li:last-child {
    border-bottom: 0;
  }

  .role-name {
    font-size: 16px;
    color: var(--ink);
    flex: 1;
    min-width: 200px;
  }

  .role-name strong {
    color: var(--oxblood);
    font-weight: 700;
  }

  .role-show {
    font-size: 16px;
    color: var(--ink);
  }

  .role-season {
    font-family: var(--font-display);
    font-size: 12px;
    color: var(--muted);
    white-space: nowrap;
