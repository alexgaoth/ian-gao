---
import Layout from '../layouts/Layout.astro';
import Ticker from '../components/Ticker.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
import { SITE } from '../lib/site';
import { personSchema } from '../lib/schema';

const tickerItems = [
  'PRESIDENT · LELAND DEBATE',
  '19TH IN THE NATION · LD',
  'CCIR · UCSB · UCSC RESEARCH',
  'MAHAN & LOW CAMPAIGNS',
  'LEAD, THE IMPORTANCE OF BEING EARNEST',
  'CO-FOUNDER, JUSTICE FOR ALL',
];

const debateResults = [
  { event: 'NSDA Nationals, LD', result: '19th in the Nation', year: '2026' },
  { event: 'CA State Championships', result: 'Top 30', year: '2026' },
  { event: 'Philhistorian Invitational, Open LD', result: 'Champion', year: '2024' },
  { event: 'NSDA Last Chance Qualifier, Open LD', result: 'First Seed, Undefeated', year: '2025' },
  { event: 'Stephen Stewart Invitational, Open LD', result: 'Quarterfinals', year: '2025' },
];

const research = [
  {
    org: 'Cambridge Center of International Research',
    tag: 'CCIR',
    mentor: 'Mentored by Oxford Professor Othon Anastasakis',
    body: 'Authored a 15,000-word original research paper, "Bosnia and Herzegovina and the Limits of International State-Building: How Stable Is the Post-Dayton Order?" Presented twice at CCIR Research Symposiums.',
  },
  {
    org: 'UC Santa Barbara — Summer Research Academies',
    tag: 'Track 11: Policy Puzzle · Jun–Jul 2025',
    mentor: 'Mentored by PhD candidate Travis Candeias',
    body: 'Co-authored "A Model Policing Agency": Analyzing the Impact of the Collaborative Reform Initiative on Use of Force in San Francisco — used R to analyze SFPD use-of-force data from 2018–2023.',
  },
  {
    org: 'UC Santa Cruz — Science Internship Program',
    tag: 'PHI-03 · Jun 2026–present',
    mentor: 'Mentored by philosophy PhD candidate Terri Preszle',
    body: '"What is Love? — A Philosophical Inquiry." Close reading and annotation of academic literature, contributing to the mentor’s doctoral thesis.',
  },
];

const campaigns = [
  {
    name: 'Matt Mahan for Governor of California',
    role: 'Campaign Intern & Phonebank Lead',
    dates: 'Feb 2026 – Jun 2026',
    body: 'Led weekly phone banking sessions with 20+ volunteers, training them to reach tens of thousands of voters. Helped run town halls and rallies across the Bay Area, and organized canvassing and literature drops across thousands of homes.',
  },
  {
    name: 'Evan Low for Congress',
    role: 'Campaign Intern',
    dates: 'Sep 2024 – Nov 2024',
    body: 'Phone banking, canvassing and literature drops (~200 houses door-to-door), and weekly team meetings on campaign strategy and event planning.',
  },
];

const productions = ['The Laramie Project', 'Mean Girls', 'The Importance of Being Earnest', 'Mamma Mia', 'Chicago', 'Clue'];
---

<Layout
  title={`${SITE.name} — Debate, Research & the Stage`}
  description="Ian Gao — Leland HS senior. President of Leland Debate, ranked 19th nationally in LD. Research at CCIR, UCSB, UCSC. Campaigns, theatre, writing."
  homepage
  structuredData={personSchema()}
>
  <!-- HERO -->
  <header id="top" class="hero">
    <div class="wrap hero-grid">
      <div>
        <p class="eyebrow accent-text">THE STUDY OF</p>
        <h1>Ian Gao</h1>
        <p class="tagline">philosophy&#8202;·&#8202;politics&#8202;·&#8202;policy</p>
        <p class="lede">
          A senior at Leland High School spending his last year of high school the way he's spent the last three:
          on a debate flow, in a research seminar, and knocking on doors for candidates he believes in.
        </p>
        <div class="cta-row">
          <a href="/writing/" class="btn btn-accent">Read the writing →</a>
          <a href="/#debate" class="btn btn-outline">The record</a>
        </div>
      </div>
      <div class="portrait-frame">
        <ImagePlaceholder label="Ian Gao — portrait" height="320px" radius="6px" />
      </div>
    </div>
  </header>

  <Ticker items={tickerItems} />

  <!-- WHO I AM -->
  <section class="section bg-cream">
    <div class="wrap who-grid">
      <div><p class="eyebrow oxblood-text">WHO I AM</p></div>
      <div>
        <p class="lead-line">
          I spend most of my time arguing — on a debate flow, in research papers, and for candidates I think deserve
          to win. Leland Debate, research at Cambridge and the UCs, and two California campaigns are three different
          rooms where I've learned to make a case and then take it apart myself.
        </p>
        <div class="two-col">
          <p>
            On a debate flow I learned to hold a position and doubt it in the same breath — the strongest case is
            the one that's already survived its best objection. That habit carried over into research: a
            15,000-word paper on post-Dayton Bosnia, a data analysis of SFPD use-of-force incidents, and right now a
            project on what love actually obligates us to.
          </p>
          <p>
            Off the flow, that same instinct shows up differently — phone banking for Matt Mahan and Evan Low,
            co-founding a courtwatching nonprofit with the San Jose Public Defender's Office, coaching debate for
            students in Cambodia and rural Pennsylvania, and getting cast as Algernon this spring. This page is the
            short version.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ACTIVE RIGHT NOW -->
  <section class="section bg-cream3 desk">
    <div class="wrap desk-row">
      <p class="eyebrow oxblood-text desk-label">ACTIVE<br />RIGHT NOW</p>
      <div class="bars">
        <div class="bar-item" style="height:100%;background:var(--oxblood)"><span>MAHAN CAMPAIGN</span></div>
        <div class="bar-item" style="height:88%;background:var(--primary)"><span>UCSC RESEARCH</span></div>
        <div class="bar-item" style="height:95%;background:var(--accent)"><span class="dark">DEBATE SEASON</span></div>
        <div class="bar-item" style="height:78%;background:var(--ink)"><span>JUSTICE FOR ALL</span></div>
        <div class="bar-item" style="height:84%;background:var(--muted)"><span>RUDI COACHING</span></div>
      </div>
      <p class="desk-note">…plus whatever round I'm prepping for this week.</p>
    </div>
  </section>

  <!-- DEBATE -->
  <section id="debate" class="section bg-cream">
    <div class="wrap">
      <div class="section-heading">
        <h2>Debate</h2>
        <span class="tag">LD · POLICY · DUO · EXTEMP</span>
      </div>
      <div class="debate-grid">
        <div class="stat-card">
          <span class="kpi oxblood-text">19th</span>
          <p class="stat-label">IN THE NATION, LD (NSDA 2026)</p>
        </div>
        <div class="stat-card">
          <span class="kpi-text">President</span>
          <p class="stat-label">LELAND SPEECH &amp; DEBATE · CAPTAIN, LD 2025–26</p>
        </div>
        <div class="results-card">
          <div class="results-head">SELECTED RESULTS</div>
          <table>
            <thead class="sr-only">
              <tr>
                <th scope="col">Tournament</th>
                <th scope="col">Result</th>
                <th scope="col">Year</th>
              </tr>
            </thead>
            <tbody>
              {debateResults.map((r) => (
                <tr>
                  <td>{r.event}</td>
                  <td class="result">{r.result}</td>
                  <td class="year">{r.year}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
      <p class="debate-footnote">
        Leads a nationally competitive team of 300 students, ranked 3rd in the nation — managing tournament
        registration, writing lesson plans, mentoring novice debaters, and running bimonthly topic research on
        issues like plea bargaining, the living wage, wealth taxes, and artificial general intelligence.
      </p>
    </div>
  </section>

  <!-- RESEARCH -->
  <section id="research" class="section bg-cream3">
    <div class="wrap">
      <div class="section-heading">
        <h2>Research</h2>
        <span class="tag">HISTORY · POLICY · PHILOSOPHY</span>
      </div>
      <div class="research-grid">
        {research.map((r) => (
          <div class="research-card">
            <p class="research-tag">{r.tag}</p>
            <h3>{r.org}</h3>
            <p class="research-mentor">{r.mentor}</p>
            <p class="research-body">{r.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CAMPAIGNING -->
  <section id="campaigning" class="section bg-cream">
    <div class="wrap">
      <div class="section-heading">
        <h2>Campaigning</h2>
        <span class="tag">CALIFORNIA CAMPAIGNS</span>
      </div>
      <div class="campaign-grid">
        {campaigns.map((c) => (
          <div class="campaign-card">
            <div class="campaign-head">
              <h3>{c.name}</h3>
              <span class="campaign-dates">{c.dates}</span>
            </div>
            <p class="campaign-role">{c.role}</p>
            <p class="campaign-body">{c.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STAGE -->
  <section id="stage" class="section bg-cream3">
    <div class="wrap">
      <div class="section-heading">
        <h2>On Stage</h2>
        <span class="tag">LELAND THEATRE</span>
      </div>
      <div class="stage-photos">
        <ImagePlaceholder label="Production still" height="260px" radius="8px" />
        <ImagePlaceholder label="Production still" height="260px" radius="8px" />
      </div>
      <p class="stage-body">
        Six productions with Leland Theatre since 2023 — <em>The Laramie Project</em>, <em>Mean Girls</em>,{' '}
        <em>The Importance of Being Earnest</em> (lead, Algernon), <em>Mamma Mia</em>, <em>Chicago</em>, and{' '}
        <em>Clue</em>.
      </p>
      <ul class="production-list">
        {productions.map((p) => (
          <li>{p}</li>
        ))}
      </ul>
      <a href="https://youtu.be/_pUo7QA8DPk" class="stage-link" rel="noopener">Watch a performance sample ↗</a>
    </div>
  </section>

  <!-- PINNED ASIDE -->
  <section class="pinned-wrap">
    <div class="pinned-note">
      <p>
        off the record — also a Leland Track long-jumper, fluent enough in Spanish to have a gold medal to prove
        it, and the reason Justice For All's group chat never sleeps.
      </p>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="section bg-cream contact">
    <div class="wrap">
      <h2>Get in touch</h2>
      <p class="contact-body">The best way to reach me is a short email — I read all of them.</p>
      <div class="contact-row">
        <a href={`mailto:${SITE.email}`} class="btn btn-primary">✉&#8202;&#8202; Email me</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    background: var(--primary);
    color: var(--on-primary);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(900px 500px at 78% -10%, color-mix(in oklab, var(--accent) 22%, transparent), transparent 60%);
    pointer-events: none;
  }

  .hero-grid {
    padding-block: 60px 70px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
    position: relative;
  }

  @media (min-width: 860px) {
    .hero-grid {
      grid-template-columns: 1.55fr 1fr;
      padding-block: 76px 84px;
    }
  }

  .accent-text {
    color: var(--accent);
    margin: 0 0 22px;
  }

  .hero h1 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(46px, 9vw, 82px);
    line-height: 0.9;
    letter-spacing: -0.03em;
    color: var(--on-primary);
    margin: 0;
  }

  .tagline {
    font-size: 20px;
    font-style: italic;
    color: var(--on-primary-soft);
    margin: 18px 0 0;
  }

  .lede {
    font-size: 18px;
    line-height: 1.6;
    color: var(--on-primary-soft);
    margin: 26px 0 0;
    max-width: 30em;
  }

  .cta-row {
    display: flex;
    gap: 14px;
    margin-top: 32px;
    flex-wrap: wrap;
  }

  .btn {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.04em;
    padding: 13px 22px;
    border-radius: 7px;
    display: inline-block;
  }

  .btn-accent {
    color: var(--primary);
    background: var(--accent);
  }

  .btn-accent:hover {
    filter: brightness(1.06);
    color: var(--primary);
  }

  .btn-outline {
    color: var(--on-primary);
    border: 1px solid var(--on-primary-soft);
  }

  .btn-outline:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .btn-primary {
    color: var(--on-primary);
    background: var(--primary);
    font-size: 14px;
    padding: 15px 28px;
  }

  .btn-primary:hover {
    filter: brightness(1.1);
    color: var(--on-primary);
  }

  .portrait-frame {
    justify-self: center;
    padding: 10px;
    border: 1px solid var(--primary-tint);
    border-radius: 10px;
    background: color-mix(in oklab, var(--primary) 70%, black 8%);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.28);
    width: 250px;
  }

  .section {
    padding-block: clamp(50px, 8vw, 82px);
  }

  .bg-cream {
    background: var(--cream);
  }

  .bg-cream3 {
    background: var(--cream3);
    border-top: 1px solid color-mix(in oklab, var(--ink) 12%, transparent);
    border-bottom: 1px solid color-mix(in oklab, var(--ink) 12%, transparent);
  }

  .who-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 30px;
  }

  @media (min-width: 780px) {
    .who-grid {
      grid-template-columns: 220px 1fr;
      gap: 56px;
    }
  }

  .oxblood-text {
    color: var(--oxblood);
    margin: 6px 0 0;
  }

  .lead-line {
    font-size: clamp(22px, 3vw, 30px);
    line-height: 1.35;
    color: var(--ink);
    margin: 0 0 26px;
    font-weight: 500;
    text-wrap: pretty;
  }

  .two-col {
    columns: 1;
    column-gap: 44px;
    font-size: 17px;
    line-height: 1.62;
    color: var(--ink);
  }

  @media (min-width: 680px) {
    .two-col {
      columns: 2;
    }
  }

  .two-col p {
    margin: 0 0 16px;
    break-inside: avoid;
  }

  .desk-row {
    display: flex;
    align-items: center;
    gap: 44px;
    flex-wrap: wrap;
    padding-block: 44px;
  }

  .desk-label {
    flex: none;
    margin: 0;
  }

  .bars {
    display: flex;
    align-items: flex-end;
    gap: 9px;
    height: 104px;
    flex-wrap: wrap;
  }

  .bar-item {
    width: 34px;
    border-radius: 3px 3px 0 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bar-item span {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 9.5px;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.85);
  }

  .bar-item span.dark {
    color: var(--primary);
  }

  .desk-note {
    font-size: 16px;
    font-style: italic;
    color: var(--muted);
    margin: 0;
    flex: 1;
    min-width: 200px;
  }

  .debate-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    align-items: stretch;
  }

  @media (min-width: 780px) {
    .debate-grid {
      grid-template-columns: 1fr 1fr 1.4fr;
    }
  }

  .stat-card {
    border: 1px solid var(--accent);
    border-radius: 10px;
    padding: 22px;
    background: var(--cream2);
  }

  .kpi {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 52px;
    line-height: 0.85;
  }

  .kpi-text {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 34px;
    line-height: 0.9;
    color: var(--primary);
  }

  .stat-label {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin: 12px 0 0;
  }

  .results-card {
    border: 1px solid color-mix(in oklab, var(--ink) 16%, transparent);
    border-radius: 10px;
    overflow: hidden;
    background: var(--cream2);
  }

  .results-head {
    background: var(--primary);
    padding: 9px 16px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--accent);
  }

  .results-card table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-display);
    font-size: 13px;
  }

  .results-card td {
    padding: 9px 16px;
    border-bottom: 1px solid color-mix(in oklab, var(--ink) 10%, transparent);
    color: var(--ink);
  }

  .results-card tr:last-child td {
    border-bottom: 0;
  }

  .result {
    text-align: right;
    color: var(--oxblood);
    font-weight: 700;
  }

  .year {
    text-align: right;
    color: var(--muted);
    font-size: 11px;
    white-space: nowrap;
    padding-left: 8px;
  }

  .debate-footnote {
    margin: 28px 0 0;
    font-size: 15.5px;
    line-height: 1.6;
    color: var(--muted);
    max-width: 62em;
  }

  .research-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 780px) {
    .research-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .research-card {
    border: 1px solid color-mix(in oklab, var(--ink) 14%, transparent);
    border-radius: 10px;
    padding: 22px;
    background: var(--cream2);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .research-tag {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--oxblood);
    margin: 0;
    text-transform: uppercase;
  }

  .research-card h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 17px;
    color: var(--primary);
    margin: 0;
  }

  .research-mentor {
    font-size: 13.5px;
    font-style: italic;
    color: var(--muted);
    margin: 0;
  }

  .research-body {
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink);
    margin: 0;
  }

  .campaign-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 700px) {
    .campaign-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .campaign-card {
    border: 1px solid color-mix(in oklab, var(--ink) 14%, transparent);
    border-radius: 10px;
    padding: 22px;
    background: var(--cream2);
  }

  .campaign-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
  }

  .campaign-head h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 17px;
    color: var(--primary);
    margin: 0;
  }

  .campaign-dates {
    font-family: var(--font-display);
    font-size: 11px;
    color: var(--muted);
    white-space: nowrap;
  }

  .campaign-role {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--oxblood);
    margin: 8px 0 10px;
  }

  .campaign-body {
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink);
    margin: 0;
  }

  .stage-photos {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 26px;
  }

  .stage-body {
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink);
    margin: 0 0 18px;
    max-width: 62em;
  }

  .production-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
    list-style: none;
    padding: 0;
    margin: 0 0 20px;
    font-family: var(--font-display);
    font-size: 12px;
    letter-spacing: 0.03em;
    color: var(--muted);
  }

  .production-list li::before {
    content: '·';
    margin-right: 12px;
    color: var(--accent);
  }

  .production-list li:first-child::before {
    content: '';
    margin-right: 0;
  }

  .stage-link {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.03em;
    color: var(--oxblood);
  }

  .pinned-wrap {
    background: var(--primary);
    padding: 60px 24px;
    display: flex;
    justify-content: center;
  }

  .pinned-note {
    transform: rotate(-1.6deg);
    background: var(--cream2);
    border-radius: 3px;
    padding: 26px 30px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.32);
    max-width: 440px;
  }

  .pinned-note p {
    font-family: var(--font-hand);
    font-weight: 600;
    font-size: 24px;
    line-height: 1.3;
    color: var(--oxblood);
    margin: 0;
  }

  .contact {
    text-align: center;
  }

  .contact h2 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(32px, 5vw, 44px);
    letter-spacing: -0.02em;
    color: var(--primary);
    margin: 0 0 14px;
  }

  .contact-body {
    font-size: 19px;
    color: var(--muted);
    margin: 0 auto 30px;
    max-width: 34em;
  }

  .contact-row {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
