---
import { SITE } from '../lib/site';
const year = new Date().getFullYear();
---

<footer>
  <div class="wrap bar">
    <span class="name">{SITE.name}</span>
    <p class="summary">
      Ian Gao ({SITE.legalName}) · {SITE.school}, {SITE.locality} · President, Leland Speech and Debate · ranked 19th
      nationally in Lincoln-Douglas · research at CCIR, UC Santa Barbara &amp; UC Santa Cruz · campaign work for Matt
      Mahan &amp; Evan Low · © {year}
    </p>
  </div>
</footer>

<style>
  footer {
    background: var(--primary-dd);
    color: var(--on-primary-soft);
  }

  .bar {
    padding-block: 34px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .name {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 16px;
    color: var(--on-primary);
  }

  .summary {
    font-family: var(--font-display);
    font-size: 11.5px;
    line-height: 1.7;
    letter-spacing: 0.02em;
    margin: 0;
    flex: 1;
    min-width: 280px;
    text-align: right;
  }

  @media (max-width: 640px) {
    .summary {
      text-align: left;
    }
  }
</style>
