---
import { SITE } from '../lib/site';

interface Props {
  title: string;
  description: string;
  homepage?: boolean;
  type?: 'website' | 'article';
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, homepage = false, type = 'website', structuredData } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, SITE.url);
const pageTitle = homepage ? title : `${title} — ${SITE.titleSuffix}`;
const schemas = structuredData ? (Array.isArray(structuredData) ? structuredData : [structuredData]) : [];
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title={`${SITE.name} — Writing`} href="/rss.xml" />

<meta property="og:type" content={type} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:image" content={new URL('/og-image.png', SITE.url)} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL('/og-image.png', SITE.url)} />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700;800;900&family=Newsreader:ital,opsz,wght@0,18..72,400;0,18..72,500;1,18..72,400;1,18..72,500&family=Caveat:wght@600;700&display=swap"
  rel="stylesheet"
/>

{schemas.map((schema) => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
